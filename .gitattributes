#
# https://help.github.com/articles/dealing-with-line-endings/
#

# Auto detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Java source files
*.java          text eol=lf
*.kt            text eol=lf
*.groovy        text eol=lf
*.gradle        text eol=lf

# JSON, XML, and config files
*.json          text eol=lf
*.json5         text eol=lf
*.xml           text eol=lf
*.toml          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.properties    text eol=lf

# Documentation
*.md            text eol=lf
*.txt           text eol=lf

# Linux start script should use lf
/gradlew        text eol=lf
*.sh            text eol=lf

# These are Windows script files and should use crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binary files (don't modify)
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.jar           binary
*.zip           binary
*.tar           binary
*.gz            binary
*.ogg           binary
*.wav           binary

